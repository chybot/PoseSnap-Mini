.favorites-page {
  height: 100vh;
  background: var(--bg-secondary);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 240rpx;
}

.empty-icon { font-size: 96rpx; margin-bottom: 24rpx; }
.empty-title { font-size: 32rpx; color: var(--text-primary); margin-bottom: 8rpx; }
.empty-desc { font-size: 24rpx; color: var(--text-hint); margin-bottom: 32rpx; }
.empty-btn {
  padding: 16rpx 48rpx;
  background: var(--theme-color);
  color: #fff;
  border-radius: 32rpx;
  font-size: 28rpx;
}

.fav-scroll { height: 100%; }

.fav-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx;
  gap: 16rpx;
}

.fav-card {
  width: calc(50% - 8rpx);
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.fav-image {
  width: 100%;
  height: 240rpx;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.fav-placeholder { font-size: 80rpx; }

.fav-difficulty {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  color: #fff;
}
.fav-difficulty.beginner { background: #4CAF50; }
.fav-difficulty.intermediate { background: #FF9800; }
.fav-difficulty.advanced { background: #F44336; }

.fav-info { padding: 16rpx; }
.fav-name { font-size: 28rpx; font-weight: bold; }

.fav-actions {
  display: flex;
  justify-content: space-between;
  margin-top: 12rpx;
}

.fav-try {
  font-size: 24rpx;
  color: var(--theme-color);
  border: 2rpx solid var(--theme-color);
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.fav-remove {
  font-size: 24rpx;
  color: var(--text-hint);
}
