<view class="camera-page">
  <!-- Camera preview -->
  <camera
    class="camera-preview"
    device-position="{{cameraPosition}}"
    flash="off"
    binderror="onCameraError"
  />

  <!-- Pose contour PNG overlay (hidden instead of wx:if to avoid re-compositing) -->
  <image
    class="contour-overlay"
    hidden="{{!(showGuide && selectedPose)}}"
    src="{{contourSrc}}"
    mode="aspectFit"
  />

  <!-- UI Controls overlay -->
  <view class="ui-overlay">
    <!-- Top bar -->
    <view class="top-bar">
      <!-- Guidance tip bubble -->
      <view class="guidance-bubble" hidden="{{!(showGuide && guidanceTip)}}">
        <text class="bubble-text">{{guidanceTip}}</text>
      </view>

      <view class="top-spacer" />

      <!-- Match score circle -->
      <view class="score-circle {{scoreClass}}" hidden="{{!(showGuide && matchScore > 0)}}">
        <text class="score-num">{{matchScore}}</text>
        <text class="score-unit">分</text>
      </view>

      <!-- Guide toggle -->
      <view class="guide-toggle {{showGuide ? 'on' : ''}}" bindtap="toggleGuide">
        <text class="toggle-text">引导</text>
      </view>
    </view>

    <!-- Tips bar -->
    <view class="pose-tips-bar" hidden="{{!(showGuide && selectedPose)}}">
      <view class="tips-header">
        <text class="tips-title">{{poseName}}</text>
        <text class="tips-difficulty">{{poseDiffLabel}}</text>
      </view>
      <view wx:for="{{poseTips}}" wx:key="*this" class="tip-row">
        <text class="tip-bullet">·</text>
        <text class="tip-content">{{item}}</text>
      </view>
    </view>

    <!-- Bottom: pose carousel + controls -->
    <view class="bottom-section">
      <!-- Pose carousel -->
      <view class="carousel-wrap">
        <scroll-view class="carousel-scroll" scroll-x enhanced show-scrollbar="{{false}}">
          <view
            wx:for="{{recommendedPoses}}"
            wx:key="id"
            class="pose-thumb {{selectedPoseId === item.id ? 'selected' : ''}}"
            bindtap="selectPose"
            data-id="{{item.id}}"
          >
            <text class="thumb-name">{{item.name}}</text>
          </view>
        </scroll-view>
      </view>

      <!-- Controls row -->
      <view class="controls-row">
        <view class="ctrl-btn" bindtap="switchCamera">
          <text class="ctrl-icon">🔄</text>
          <text class="ctrl-label">翻转</text>
        </view>

        <view class="shutter-btn" bindtap="takePhoto">
          <view class="shutter-inner" />
        </view>

        <view class="ctrl-btn" bindtap="openLibrary">
          <text class="ctrl-icon">📖</text>
          <text class="ctrl-label">姿势库</text>
        </view>
      </view>

      <!-- Mode tabs -->
      <view class="mode-tabs">
        <text class="mode-tab" bindtap="switchMode" data-mode="video">录像</text>
        <text class="mode-tab active">拍照</text>
        <text class="mode-tab" bindtap="switchMode" data-mode="portrait">人像</text>
      </view>
    </view>
  </view>
</view>
