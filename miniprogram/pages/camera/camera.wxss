.camera-page {
  width: 100vw;
  height: 100vh;
  position: relative;
  overflow: hidden;
}

.camera-preview {
  width: 100%;
  height: 100%;
}

/* Contour PNG overlay */
.contour-overlay {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 55%;
  height: auto;
  opacity: 0.45;
  pointer-events: none;
}

/* UI overlay */
.ui-overlay {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  display: flex;
  flex-direction: column;
}

/* ===== Top bar ===== */
.top-bar {
  display: flex;
  align-items: center;
  padding: 100rpx 24rpx 16rpx;
  gap: 12rpx;
}

.scene-tag {
  background: rgba(0,0,0,0.45);
  border-radius: 24rpx;
  padding: 8rpx 20rpx;
}

.scene-text {
  color: #fff;
  font-size: 24rpx;
}

/* Guidance bubble */
.guidance-bubble {
  background: rgba(0,0,0,0.55);
  border-radius: 16rpx;
  padding: 12rpx 24rpx;
  max-width: 450rpx;
}

.bubble-text {
  color: #fff;
  font-size: 26rpx;
  font-weight: 500;
  line-height: 1.4;
}

.top-spacer { flex: 1; }

/* Score circle */
.score-circle {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.5);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 3rpx solid rgba(255,255,255,0.3);
}

.score-circle.high {
  background: rgba(76,175,80,0.6);
  border-color: #4CAF50;
}

.score-circle.medium {
  background: rgba(255,152,0,0.6);
  border-color: #FF9800;
}

.score-num {
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
  line-height: 1;
}

.score-unit {
  color: rgba(255,255,255,0.7);
  font-size: 18rpx;
}

/* Guide toggle */
.guide-toggle {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255,255,255,0.3);
}

.guide-toggle.on {
  background: rgba(255,107,107,0.6);
  border-color: #FF6B6B;
}

.toggle-text {
  color: #fff;
  font-size: 20rpx;
}

/* ===== Tips bar ===== */
.pose-tips-bar {
  margin: 0 24rpx;
  margin-top: auto;
  padding: 16rpx 20rpx;
  background: rgba(0,0,0,0.5);
  border-radius: 16rpx;
}

.tips-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.tips-title {
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
}

.tips-difficulty {
  color: #4CAF50;
  font-size: 20rpx;
  background: rgba(76,175,80,0.2);
  padding: 2rpx 12rpx;
  border-radius: 12rpx;
}

.tip-row {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  margin-top: 4rpx;
}

.tip-bullet {
  color: rgba(255,255,255,0.6);
  font-size: 24rpx;
  flex-shrink: 0;
}

.tip-content {
  color: rgba(255,255,255,0.85);
  font-size: 24rpx;
  line-height: 1.4;
}

/* ===== Bottom section ===== */
.bottom-section {
  padding: 16rpx 0 40rpx;
  background: linear-gradient(to bottom, transparent, rgba(0,0,0,0.65));
}

/* Carousel */
.carousel-wrap {
  padding: 0 24rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.carousel-scroll {
  display: flex;
  gap: 12rpx;
  overflow-x: auto;
}

.pose-thumb {
  flex-shrink: 0;
  width: 96rpx;
  height: 96rpx;
  background: rgba(255,255,255,0.12);
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid transparent;
}

.pose-thumb.selected {
  background: rgba(255,255,255,0.28);
  border-color: rgba(255,255,255,0.8);
}

.thumb-name {
  color: #fff;
  font-size: 20rpx;
  text-align: center;
}

/* Controls */
.controls-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 72rpx;
  padding: 8rpx 0;
}

.ctrl-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.ctrl-icon { font-size: 44rpx; }

.ctrl-label {
  color: rgba(255,255,255,0.7);
  font-size: 20rpx;
}

.shutter-btn {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  border: 5rpx solid rgba(255,255,255,0.8);
  display: flex;
  align-items: center;
  justify-content: center;
}

.shutter-inner {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: #fff;
}

/* Mode tabs */
.mode-tabs {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  padding-top: 16rpx;
}

.mode-tab {
  color: rgba(255,255,255,0.5);
  font-size: 26rpx;
}

.mode-tab.active {
  color: #fff;
  font-weight: bold;
  font-size: 28rpx;
}
