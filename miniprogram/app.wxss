/* PoseSnap Global Styles */
page {
  --theme-color: #FF6B6B;
  --theme-light: #FFE5E5;
  --bg-primary: #ffffff;
  --bg-secondary: #f8f8f8;
  --text-primary: #1a1a1a;
  --text-secondary: #666666;
  --text-hint: #999999;
  --border-color: #eeeeee;
  --success: #4CAF50;
  --warning: #FF9800;
  --danger: #F44336;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
  background-color: var(--bg-secondary);
}

/* Custom nav bar */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #fff;
}

.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  padding: 0 100rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.nav-back {
  position: absolute;
  left: 24rpx;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  padding-right: 20rpx;
  font-size: 36rpx;
  color: var(--text-primary);
}

.custom-nav.dark {
  background: #1a1a1a;
}

.custom-nav.dark .nav-title {
  color: #fff;
}

.custom-nav.dark .nav-back {
  color: #fff;
}

/* Utility classes */
.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
